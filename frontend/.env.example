# Backend API URL (e.g., https://your-backend.railway.app or http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# Set to "true" to use mock data instead of real API (for frontend-only development)
VITE_USE_MOCK=false

# Gemini API key for AI features (optional - AI panel will show placeholder if not set)
VITE_GEMINI_API_KEY=
